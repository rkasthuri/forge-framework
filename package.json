{
  "name": "e2e-ai-testing-framework",
  "version": "1.0.0",
  "description": "AI-powered E2E testing framework",
  "main": "index.js",
  "scripts": {
    "check": "npm run check:core",
    "check:core": "tsc --noEmit",
    "test": "npx tsx src/run.ts --smoke",
    "test:all": "npx tsx src/run.ts --stable",
    "test:flaky": "npx playwright test --grep \"@slow|@flaky\"",
    "test:full": "npx tsx src/run.ts --full",
    "test:login": "playwright test loginFast.spec.ts --headed",
    "test:inventory": "playwright test inventory.spec.ts --headed",
    "test:cart": "playwright test cart.spec.ts --headed",
    "test:checkout": "playwright test checkout.spec.ts --headed",
    "test:e2e": "playwright test e2e-journey.spec.ts --headed",
    "test:edge": "playwright test edgeCases.spec.ts --headed",
    "test:smoke": "playwright test loginFast.spec.ts e2e-journey.spec.ts --headed",
    "test:report": "playwright show-report reports/playwright-report",
    "agent:explore": "tsx src/agents/siteExplorer.ts",
    "triage": "npx tsx src/pipeline/ai-triage.ts",
    "triage:verbose": "npx tsx src/pipeline/ai-triage.ts --verbose",
    "store": "npx tsx src/pipeline/results-store.ts",
    "fixes": "npx tsx src/pipeline/adaptive-fixes.ts",
    "fixes:dry": "npx tsx src/pipeline/adaptive-fixes.ts --dry-run",
    "impact": "npx tsx src/pipeline/impact-analysis.ts",
    "impact:dry": "npx tsx src/pipeline/impact-analysis.ts --dry-run",
    "generate": "npx tsx src/pipeline/nl-test-generator.ts",
    "generate:preview": "npx tsx src/pipeline/nl-test-generator.ts --preview",
    "trends": "npx tsx src/pipeline/trend-analysis.ts",
    "trends:open": "npx tsx src/pipeline/trend-analysis.ts --open",
    "query": "npx tsx src/pipeline/knowledge-query.ts",
    "query:rebuild": "npx tsx src/pipeline/knowledge-query.ts --rebuild",
    "query:ui": "npx tsx src/platform/query-server.ts",
    "visual:baseline": "npx tsx src/pipeline/visual-regression.ts --baseline",
    "visual:compare": "npx tsx src/pipeline/visual-regression.ts --open",
    "visual:page": "npx tsx src/pipeline/visual-regression.ts --page",
    "perf:baseline": "npx tsx src/pipeline/performance-baseline.ts --baseline",
    "perf:compare": "npx tsx src/pipeline/performance-baseline.ts --open",
    "dashboard": "npx tsx src/platform/dashboard-server.ts",
    "visual:cross-browser": "tsx src/pipeline/cross-browser-visual.ts",
    "visual:cross-browser:capture": "tsx src/pipeline/cross-browser-visual.ts --capture",
    "visual:cross-browser:page": "tsx src/pipeline/cross-browser-visual.ts --page",
    "test:api": "npx playwright test src/apps/desktop/api/restful-booker/tests/api.spec.ts --reporter=list",
    "test:api:verbose": "npx playwright test src/apps/desktop/api/restful-booker/tests/api.spec.ts --reporter=list --headed",
    "test:api:report": "npx playwright test src/apps/desktop/api/restful-booker/tests/api.spec.ts && start reports\\playwright-report\\index.html",
    "predict:flaky": "tsx src/pipeline/flaky-predictor.ts",
    "predict:flaky:summary": "tsx src/pipeline/flaky-predictor.ts --summary",
    "predict:flaky:strict": "tsx src/pipeline/flaky-predictor.ts --threshold=60",
    "release:notes": "tsx src/pipeline/release-notes.ts --open",
    "release:notes:sprint": "tsx src/pipeline/release-notes.ts --sprint",
    "release:notes:full": "tsx src/pipeline/release-notes.ts --runs=14 --open",
    "notify": "tsx src/pipeline/notifier.ts",
    "notify:slack": "tsx src/pipeline/notifier.ts --slack-only",
    "notify:email": "tsx src/pipeline/notifier.ts --email-only",
    "notify:test": "tsx src/pipeline/notifier.ts --level=critical",
    "coverage:gaps": "tsx src/pipeline/coverage-gap.ts",
    "coverage:area": "tsx src/pipeline/coverage-gap.ts --area=checkout",
    "coverage:query": "tsx src/pipeline/coverage-gap.ts --query=",
    "coverage:next-id": "tsx src/pipeline/coverage-gap.ts --next-id",
    "gaps:generate": "tsx src/pipeline/gap-to-test.ts",
    "gaps:preview": "tsx src/pipeline/gap-to-test.ts --preview",
    "gaps:p0-only": "tsx src/pipeline/gap-to-test.ts --priority=P0",
    "gaps:all": "tsx src/pipeline/gap-to-test.ts --all",
    "platform": "tsx src/platform/platform-server.ts",
    "platform:dev": "tsx --watch src/platform/platform-server.ts",
    "platform:stop": "powershell -Command \"$p = (netstat -ano | findstr :4280 | Select-Object -First 1) -split '\\s+' | Select-Object -Last 1; taskkill /PID $p /F\"",
    "db:migrate": "tsx src/core/storage/migrate.ts",
    "db:migrate:down": "tsx src/core/storage/migrate.ts --down",
    "db:studio": "echo Open ryq-framework.db in TablePlus or DB Browser for SQLite",
    "db:purge": "tsx scripts/purge.ts",
    "db:status": "node -e \"const D=require('better-sqlite3');const db=new D('./ryq-framework.db');['runs','heal_events','ai_usage','flaky_analysis','coverage_gaps','trends','dom_snapshots','assertions'].forEach(t=>{const n=db.prepare('SELECT COUNT(*) as n FROM '+t).get();console.log(t+':',n.n,'rows')});db.close()\"",
    "onboard": "tsx src/core/onboarding/cli.ts crawl",
    "onboard:verify": "tsx src/core/onboarding/cli.ts verify",
    "onboard:generate": "tsx src/core/onboarding/cli.ts generate",
    "onboard:refresh": "tsx src/core/onboarding/cli.ts refresh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "kysely": "^0.29.2",
    "kysely-wasm": "^1.2.1",
    "node-sqlite3-wasm": "^0.8.58",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "playwright": "^1.49.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0"
  }
}
