{
  "name": "e2e-ai-testing-framework",
  "version": "1.0.0",
  "description": "AI-powered E2E testing framework",
  "main": "index.js",
  "scripts": {
    "test": "npx tsx src/run.ts --smoke",
    "test:all": "npx tsx src/run.ts --stable",
    "test:flaky": "npx playwright test --grep \"@slow|@flaky\"",
    "test:full": "npx tsx src/run.ts --full",
    "test:login": "playwright test loginFast.spec.ts --headed",
    "test:inventory": "playwright test inventory.spec.ts --headed",
    "test:cart": "playwright test cart.spec.ts --headed",
    "test:checkout": "playwright test checkout.spec.ts --headed",
    "test:e2e": "playwright test e2e-journey.spec.ts --headed",
    "test:edge": "playwright test edgeCases.spec.ts --headed",
    "test:smoke": "playwright test loginFast.spec.ts e2e-journey.spec.ts --headed",
    "test:report": "playwright show-report reports/playwright-report",
    "agent:explore": "tsx src/agents/siteExplorer.ts",
    "triage": "npx tsx src/ai-triage.ts",
    "triage:verbose": "npx tsx src/ai-triage.ts --verbose",
    "store": "npx tsx src/results-store.ts",
    "fixes": "npx tsx src/adaptive-fixes.ts",
    "fixes:dry": "npx tsx src/adaptive-fixes.ts --dry-run",
    "impact": "npx tsx src/impact-analysis.ts",
    "impact:dry": "npx tsx src/impact-analysis.ts --dry-run",
    "generate": "npx tsx src/nl-test-generator.ts",
    "generate:preview": "npx tsx src/nl-test-generator.ts --preview",
    "trends": "npx tsx src/trend-analysis.ts",
    "trends:open": "npx tsx src/trend-analysis.ts --open",
    "query": "npx tsx src/knowledge-query.ts",
    "query:rebuild": "npx tsx src/knowledge-query.ts --rebuild",
    "query:ui": "npx tsx src/query-server.ts",
    "visual:baseline": "npx tsx src/visual-regression.ts --baseline",
    "visual:compare": "npx tsx src/visual-regression.ts --open",
    "visual:page": "npx tsx src/visual-regression.ts --page",
    "perf:baseline": "npx tsx src/performance-baseline.ts --baseline",
    "perf:compare": "npx tsx src/performance-baseline.ts --open",
    "dashboard": "npx tsx src/dashboard-server.ts",
    "visual:cross-browser": "tsx src/cross-browser-visual.ts",
    "visual:cross-browser:capture": "tsx src/cross-browser-visual.ts --capture",
    "visual:cross-browser:page": "tsx src/cross-browser-visual.ts --page",
    "test:api": "npx playwright test src/tests/api.spec.ts --reporter=list",
    "test:api:verbose": "npx playwright test src/tests/api.spec.ts --reporter=list --headed",
    "test:api:report": "npx playwright test src/tests/api.spec.ts && start reports\\playwright-report\\index.html",
    "predict:flaky": "tsx src/flaky-predictor.ts",
    "predict:flaky:summary": "tsx src/flaky-predictor.ts --summary",
    "predict:flaky:strict": "tsx src/flaky-predictor.ts --threshold=60",
    "release:notes": "tsx src/release-notes.ts --open",
    "release:notes:sprint": "tsx src/release-notes.ts --sprint",
    "release:notes:full": "tsx src/release-notes.ts --runs=14 --open",
    "notify": "tsx src/notifier.ts",
    "notify:slack": "tsx src/notifier.ts --slack-only",
    "notify:email": "tsx src/notifier.ts --email-only",
    "notify:test": "tsx src/notifier.ts --level=critical"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "dotenv": "^16.4.7",
    "nodemailer": "^8.0.10",
    "playwright": "^1.49.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0"
  }
}
