{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ryq-framework/app-model.schema.json",
  "title": "RYQ App Model",
  "description": "Versioned contract produced by the crawler and consumed by generators",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "generatedBy",
    "app",
    "roles",
    "pages",
    "flows"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version \u2014 bump when shape changes. 2.0: crawl-execution provenance moved into app.crawlMetadata (nullable); evidenceState added (TD-UI-031)."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generatedBy": {
      "type": "string",
      "enum": [
        "engine",
        "agent",
        "human",
        "import"
      ]
    },
    "app": {
      "type": "object",
      "required": [
        "name",
        "displayName",
        "baseUrl",
        "appType",
        "modelVersion",
        "evidenceState",
        "crawlMetadata"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Matches APP_NAME env var"
        },
        "displayName": {
          "type": "string"
        },
        "baseUrl": {
          "type": "string",
          "format": "uri"
        },
        "appType": {
          "type": "string",
          "enum": [
            "web-ui",
            "mpa",
            "spa",
            "rest-api",
            "graphql-api",
            "mobile-android",
            "mobile-ios",
            "iot",
            "cloud",
            "data",
            "api"
          ]
        },
        "modelVersion": {
          "type": "string",
          "description": "Semver \u2014 auto-incremented on re-crawl"
        },
        "spaConfig": {
          "description": "Null for MPA \u2014 populated for SPA in Phase 6",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "required": [
                "fingerprintBasis",
                "stateGraphDepth",
                "dynamicRoutePatterns"
              ],
              "properties": {
                "fingerprintBasis": {
                  "type": "string",
                  "enum": [
                    "url-only",
                    "url+dom-hash"
                  ]
                },
                "stateGraphDepth": {
                  "type": "integer"
                },
                "dynamicRoutePatterns": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          ]
        },
        "evidenceState": {
          "type": "string",
          "enum": [
            "crawled",
            "crawled-empty",
            "unsupported-platform"
          ],
          "description": "Authored at the producer (Crawler.buildModel / ApiSpecCrawler / buildStubModel), derived from observed content. Never defaulted (TD-UI-031)."
        },
        "crawlMetadata": {
          "description": "Crawl-execution provenance. null ONLY for unsupported-platform (no crawl ran) — ADR-015 Corollary 1: reaching for .crawledAt on null is a type error.",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "crawlConfigHash",
                "crawledAt",
                "crawledBy",
                "crawlDurationMs",
                "pagesBudget",
                "pagesDiscovered",
                "pagesSkipped",
                "aiBudgetStatus",
                "crawlDiagnostics"
              ],
              "properties": {
                "crawlConfigHash": {
                  "type": "string",
                  "description": "sha256 of the crawl config (moved from app — TD-UI-031 Q4)"
                },
                "crawledAt": {
                  "type": "string",
                  "format": "date-time"
                },
                "crawledBy": {
                  "type": "string",
                  "enum": [
                    "engine",
                    "agent",
                    "human",
                    "import"
                  ]
                },
                "crawlDurationMs": {
                  "type": "integer"
                },
                "pagesBudget": {
                  "type": "integer",
                  "description": "ONBOARD_MAX_PAGES at crawl time — a fact about the run"
                },
                "pagesDiscovered": {
                  "type": "integer"
                },
                "pagesSkipped": {
                  "type": ["integer", "null"],
                  "description": "null = not measured (frontier not instrumented — TD-UI-054); 0 would mean measured-and-none, a different claim"
                },
                "aiBudgetStatus": {
                  "type": "string",
                  "enum": [
                    "within-budget",
                    "degraded"
                  ]
                },
                "crawlDiagnostics": {
                  "description": "null = clean crawl, no diagnostics. Populated (esp. crawled-empty) with machine-readable failure reasons + remedies (TD-UI-040).",
                  "oneOf": [
                    {
                      "type": "null"
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                          "scope",
                          "target",
                          "reason",
                          "detail"
                        ],
                        "properties": {
                          "scope": {
                            "type": "string",
                            "enum": [
                              "start-page",
                              "role",
                              "page"
                            ]
                          },
                          "target": {
                            "type": "string"
                          },
                          "reason": {
                            "type": "string",
                            "enum": [
                              "page-load-failed",
                              "auth-required",
                              "auth-failed",
                              "zero-clickables",
                              "hydration-timeout",
                              "navigation-error",
                              "login-surface-observation"
                            ]
                          },
                          "detail": {
                            "type": "string"
                          },
                          "loginSurfaceObservation": {
                            "description": "TD-148 — present ONLY on reason 'login-surface-observation'. Observation-only record of the pre-auth login surface; no comparison, no verdict, no configured value.",
                            "type": "object",
                            "additionalProperties": false,
                            "required": ["check", "observations", "note"],
                            "properties": {
                              "check": { "type": "string", "enum": ["login-surface-observation"] },
                              "observations": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "additionalProperties": false,
                                  "required": ["signal", "observation", "mechanism", "observationBoundary"],
                                  "properties": {
                                    "signal": { "type": "string", "enum": ["password-field", "app-shape", "landing-url"] },
                                    "observation": { "type": "string" },
                                    "mechanism": { "type": "string" },
                                    "observationBoundary": { "type": "string" }
                                  }
                                }
                              },
                              "note": { "type": "string" }
                            }
                          },
                          "remedy": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": [
                              "tier",
                              "action"
                            ],
                            "properties": {
                              "tier": {
                                "type": "integer",
                                "enum": [
                                  1,
                                  2,
                                  3
                                ]
                              },
                              "action": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          ]
        }
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "displayName",
          "authFlow",
          "reachablePageIds",
          "restrictedPageIds"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "authFlow": {
            "type": "string",
            "enum": [
              "form-login",
              "oauth",
              "api-key",
              "none"
            ]
          },
          "credentialsEnvKey": {
            "type": [
              "string",
              "null"
            ]
          },
          "storageStatePath": {
            "type": [
              "string",
              "null"
            ]
          },
          "reachablePageIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "restrictedPageIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "pages": {
      "description": "Null for API-only apps",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "displayName",
              "urlPattern",
              "urlPatternType",
              "fingerprint",
              "fingerprintBasis",
              "appType",
              "accessibleByRoles",
              "isAuthPage",
              "elements"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "displayName": {
                "type": "string"
              },
              "urlPattern": {
                "type": "string"
              },
              "urlPatternType": {
                "type": "string",
                "enum": [
                  "exact",
                  "prefix",
                  "regex"
                ]
              },
              "fingerprint": {
                "type": "string"
              },
              "fingerprintBasis": {
                "type": "string",
                "enum": [
                  "url-only",
                  "url+dom-hash"
                ]
              },
              "appType": {
                "type": "string"
              },
              "accessibleByRoles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "isAuthPage": {
                "type": "boolean"
              },
              "elements": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "name",
                    "kind",
                    "critical",
                    "aiNamed",
                    "strategies"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Format: {pageId}:{name}"
                    },
                    "name": {
                      "type": "string"
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "input",
                        "button",
                        "link",
                        "select",
                        "checkbox",
                        "radio",
                        "textarea",
                        "other",
                        "path-param",
                        "query-param",
                        "request-field",
                        "response-field"
                      ]
                    },
                    "label": {
                      "type": "string"
                    },
                    "critical": {
                      "type": "boolean"
                    },
                    "aiNamed": {
                      "type": "boolean"
                    },
                    "disambiguatedFrom": {
                      "type": "string",
                      "description": "Original name before a same-page collision was resolved by deduplicateNames() — see TD-018"
                    },
                    "strategies": {
                      "type": "array",
                      "minItems": 0,
                      "items": {
                        "type": "object",
                        "required": [
                          "type",
                          "value",
                          "confidence"
                        ],
                        "properties": {
                          "type": {
                            "type": "string",
                            "enum": [
                              "data-test",
                              "id",
                              "role",
                              "text",
                              "css",
                              "api-path"
                            ]
                          },
                          "value": {
                            "type": "string"
                          },
                          "confidence": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "accessibleName": {
                            "type": "string",
                            "description": "For type 'role' only — the accessible name to match alongside the bare ARIA role token in 'value'. See TD-029."
                          }
                        }
                      }
                    },
                    "tier3Assertions": {
                      "type": "array"
                    }
                  }
                }
              },
              "prerequisites": {
                "type": "array",
                "description": "Setup steps that must run before this page can be verified \u2014 see TD-013",
                "items": {
                  "type": "object",
                  "required": [
                    "steps"
                  ],
                  "properties": {
                    "roleId": {
                      "type": "string"
                    },
                    "steps": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "stepIndex",
                          "pageId",
                          "action"
                        ],
                        "properties": {
                          "stepIndex": {
                            "type": "integer"
                          },
                          "pageId": {
                            "type": "string"
                          },
                          "action": {
                            "type": "string"
                          },
                          "elementId": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "targetPageId": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "value": {
                            "type": [
                              "string",
                              "null"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "endpoints": {
      "description": "Null for UI-only apps \u2014 populated for rest-api and graphql-api",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "method",
              "path",
              "summary",
              "auth"
            ],
            "properties": {
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "PATCH",
                  "DELETE"
                ]
              },
              "path": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "auth": {
                "type": "boolean"
              },
              "parameters": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "in",
                    "required"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "in": {
                      "type": "string",
                      "enum": [
                        "path",
                        "query",
                        "header",
                        "body"
                      ]
                    },
                    "required": {
                      "type": "boolean"
                    }
                  }
                }
              },
              "requestBody": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "schema": {
                        "type": "object"
                      }
                    }
                  }
                ]
              },
              "responses": {
                "type": "object"
              }
            }
          }
        }
      ]
    },
    "flows": {
      "description": "Null for API-only apps",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "displayName",
              "confidence",
              "source",
              "roleId",
              "steps"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "displayName": {
                "type": "string"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "observed",
                  "partial",
                  "unknown"
                ]
              },
              "source": {
                "type": "string",
                "enum": [
                  "inferred",
                  "config-seeded",
                  "agent-proposed"
                ]
              },
              "roleId": {
                "type": "string"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "stepIndex",
                    "pageId",
                    "action"
                  ],
                  "properties": {
                    "stepIndex": {
                      "type": "integer"
                    },
                    "pageId": {
                      "type": "string"
                    },
                    "action": {
                      "type": "string"
                    },
                    "elementId": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "targetPageId": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "value": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              },
              "linkedApiEndpointIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      ]
    },
    "api": {
      "description": "Null for UI-only apps",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "intakeMode",
            "specSource",
            "specHash",
            "specCrawledAt",
            "auth",
            "baseUrl",
            "endpoints"
          ],
          "properties": {
            "intakeMode": {
              "type": "string",
              "enum": [
                "spec-driven",
                "traffic-inference"
              ]
            },
            "specSource": {
              "type": "string"
            },
            "specHash": {
              "type": "string"
            },
            "specCrawledAt": {
              "type": "string",
              "format": "date-time"
            },
            "auth": {
              "type": "object",
              "required": [
                "type"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "basic",
                    "bearer",
                    "api-key",
                    "none"
                  ]
                },
                "envKey": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            },
            "baseUrl": {
              "type": "string",
              "format": "uri"
            },
            "endpoints": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "method",
                  "path",
                  "operationId",
                  "knownStatusCodes"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "method": {
                    "type": "string",
                    "enum": [
                      "GET",
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE"
                    ]
                  },
                  "path": {
                    "type": "string"
                  },
                  "operationId": {
                    "type": "string"
                  },
                  "requestSchema": {
                    "type": [
                      "object",
                      "null"
                    ]
                  },
                  "responseSchema": {
                    "type": [
                      "object",
                      "null"
                    ]
                  },
                  "knownStatusCodes": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  },
                  "linkedUiFlowId": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "tier3Assertions": {
                    "type": "array"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "diff": {
      "description": "Null on first crawl \u2014 populated on re-crawl",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "properties": {
            "previousModelVersion": {
              "type": "string"
            },
            "diffGeneratedAt": {
              "type": "string",
              "format": "date-time"
            },
            "pagesAdded": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "pagesRemoved": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "pagesModified": {
              "type": ["array", "null"],
              "items": {
                "type": "string"
              }
            },
            "elementsAdded": {
              "type": ["array", "null"],
              "items": {
                "type": "string"
              }
            },
            "elementsRemoved": {
              "type": ["array", "null"],
              "items": {
                "type": "string"
              }
            },
            "strategiesInvalidated": {
              "type": ["array", "null"],
              "items": {
                "type": "string"
              }
            },
            "flowsAdded": {
              "type": ["array", "null"],
              "items": {
                "type": "string"
              }
            },
            "flowsRemoved": {
              "type": ["array", "null"],
              "items": {
                "type": "string"
              }
            }
          }
        }
      ]
    }
  },
  "oneOf": [
    {
      "title": "Shape A \u2014 UI / legacy app",
      "description": "web-ui, mpa, spa, mobile-android, mobile-ios, and legacy api type",
      "properties": {
        "app": {
          "properties": {
            "appType": {
              "enum": [
                "web-ui",
                "mpa",
                "spa",
                "mobile-android",
                "mobile-ios",
                "api"
              ]
            }
          }
        },
        "endpoints": {
          "type": "null"
        }
      }
    },
    {
      "title": "Shape B \u2014 REST / GraphQL API app",
      "description": "rest-api and graphql-api: has endpoints array, pages must be null",
      "properties": {
        "app": {
          "properties": {
            "appType": {
              "enum": [
                "rest-api",
                "graphql-api"
              ]
            }
          }
        },
        "pages": {
          "type": "null"
        }
      }
    },
    {
      "title": "Shape C \u2014 Stub / not-yet-supported app",
      "description": "iot, cloud, data: passes validation, generates nothing",
      "properties": {
        "app": {
          "properties": {
            "appType": {
              "enum": [
                "iot",
                "cloud",
                "data"
              ]
            }
          }
        },
        "endpoints": {
          "type": "null"
        },
        "pages": {
          "type": "null"
        }
      }
    }
  ],
  "allOf": [
    {
      "title": "INVARIANT — unsupported-platform has no crawl metadata",
      "description": "TD-UI-031/ADR-015: the only never-crawled state carries crawlMetadata: null.",
      "if": {
        "properties": { "app": { "properties": { "evidenceState": { "const": "unsupported-platform" } } } }
      },
      "then": {
        "properties": { "app": { "properties": { "crawlMetadata": { "type": "null" } } } }
      }
    },
    {
      "title": "INVARIANT — an executed crawl carries non-null metadata",
      "description": "crawled and crawled-empty both ran a crawl; provenance must exist.",
      "if": {
        "properties": { "app": { "properties": { "evidenceState": { "enum": ["crawled", "crawled-empty"] } } } }
      },
      "then": {
        "properties": { "app": { "properties": { "crawlMetadata": { "type": "object" } } } }
      }
    }
  ]
}
