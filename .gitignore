# ─────────────────────────────────────────────
# E2E AI Testing Framework — .gitignore
# ─────────────────────────────────────────────

# !! SECURITY — never commit secrets !!
.env
.env.local
.env.*.local
*.key
secrets.json

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
dist/
build/
*.js.map

# Playwright
test-results/
playwright-report/
playwright/.cache/

# AI Triage outputs (runtime files — not source)
test-results/results.json
test-results/triage-report.json
test-results/triage-report.md
reports/test-results.json
reports/triage-report.json
reports/triage-report.md
reports/suggested-fixes.json
reports/suggested-fixes.md
reports/impact-report.json
reports/impact-report.md
reports/generated-tests.md
reports/knowledge-index.json
reports/visual/
reports/visual-report.html
reports/visual-summary.json
reports/perf-baseline.json
reports/perf-history.json
reports/perf-report.html
reports/visual/cross-browser/
reports/flaky-predictions.json
reports/flaky-prediction-report.html
reports/release-notes.md
reports/release-notes.html
reports/release-notes.json
reports/trend-dashboard.html
reports/trend-report.md
# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.suo
*.user
